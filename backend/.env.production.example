# ─────────────────────────────────────────────────────────────────────────────
# ZuriPay — Production Environment Template
# Copy to .env and fill in real values before deploying.
# NEVER commit a file containing real secrets to version control.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=ZuriPay API
ENVIRONMENT=production

# ── Database ──────────────────────────────────────────────────────────────────
# Use a strong, unique password.  Connection pooling (e.g. PgBouncer) recommended.
DATABASE_URL=postgresql+psycopg2://zuripay:STRONG_DB_PASSWORD@localhost:5432/zuripay

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_ROOT=/var/zuripay/storage

# ── FX Rates ──────────────────────────────────────────────────────────────────
EXCHANGERATE_HOST_API_KEY=your_exchangerate_host_api_key

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use an App Password (not your account password).
# Guide: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_FROM_NAME=ZuriPay

# ── Africa's Talking ──────────────────────────────────────────────────────────
# Create a live account at https://africastalking.com
# AT_USERNAME must NOT be "sandbox" in production.
AT_USERNAME=your_africastalking_username
AT_API_KEY=your_africastalking_api_key
AT_SENDER_ID=ZuriPay
AT_PRODUCT_NAME=ZuriPay

# ── Webhooks ──────────────────────────────────────────────────────────────────
# Set this in the Africa's Talking dashboard under Payments > Webhooks.
# Generate with:  openssl rand -hex 32
WEBHOOK_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
